# ============================================================
#  .env de PRODUCCIÓN — Gestadia Portal (backend)
#  Copia este fichero a `.env` EN EL SERVIDOR de producción y
#  rellena los valores marcados con «← RELLENAR».
#  El `.env` real NUNCA se comitea (ya está en .gitignore).
#  Deja el .env local en modo test — esto es solo para el server.
# ============================================================

# --- Núcleo ---
PORT=3001
BASE_URL=https://portal.gestadia.com                 # ← RELLENAR: dominio público real (HTTPS). Se usa en success_url/cancel_url de Stripe, enlaces de emails y la URL del webhook.
DATABASE_URL="mysql://USER:PASS@HOST:3306/gestadia"   # ← RELLENAR: BD de producción (con las migraciones de Prisma aplicadas)
JWT_SECRET=                                           # ← RELLENAR: cadena larga aleatoria — genera con:  openssl rand -hex 32

# --- Stripe (MODO LIVE) — https://dashboard.stripe.com/apikeys ---
# ⚠️ Vacío = MODO DEMO (el checkout SIMULA el pago). En producción DEBE ir la clave live real.
STRIPE_SECRET_KEY=sk_live_xxx                         # ← RELLENAR: clave secreta LIVE (sk_live_…)
#
# Webhook: crear en el dashboard EN MODO LIVE, endpoint =  https://TU_DOMINIO/webhooks/stripe
# Evento a escuchar:  checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxx                       # ← RELLENAR: signing secret del webhook LIVE (whsec_…)
#
# ⚠️ IMPORTANTE: estos 8 lookup_key DEBEN existir como precios ACTIVOS en modo LIVE
#    (los precios de test NO se copian a live). Mismo lookup_key e importe:
#      gestadia_canje_1_categoria_2026        → 210 €
#      gestadia_portal_duplicado_carnet       →  70 €
#      gestadia_portal_duplicado_datos        →  70 €
#      gestadia_portal_permiso_internacional  → 100 €
#      gestadia_portal_transferencia          → 190 €
#      gestadia_portal_baja_vehiculo          → 190 €
#      gestadia_portal_cancelacion_dominio    → 120 €
#      gestadia_portal_duplicado_circulacion  →  70 €
#    (Estado 2026-07: verificados en TEST; falta confirmarlos/crearlos en LIVE.)
# ⚠️ Activar además el método de pago Bizum en la cuenta live (el checkout usa card + bizum).

# --- Zoho CRM (datacenter EU) — ya operativo contra el CRM real ---
ZOHO_CLIENT_ID=                                       # ← RELLENAR (o reutilizar las credenciales actuales)
ZOHO_CLIENT_SECRET=                                   # ← RELLENAR
ZOHO_REFRESH_TOKEN=                                   # ← RELLENAR
ZOHO_ACCOUNTS_URL=https://accounts.zoho.eu
ZOHO_API_URL=https://www.zohoapis.eu
ZOHO_API_VERSION=v6
ZOHO_WEBHOOK_SECRET=                                  # ← RELLENAR: secreto compartido con el workflow de Zoho (header X-Gestadia-Secret)

# --- Zoho: flujo de leads informativos ("Solicitar información") ---
ZOHO_LEAD_SOURCE_DEFAULT=Formulario Web
ZOHO_LEAD_STATUS_DEFAULT=No contactado
ZOHO_PAGE_SOURCE_DEFAULT=GESTADIA
ZOHO_CAMPAIGN_ID=
ZOHO_ASSIGNMENT_RULE_ID=

# --- Email transaccional (SMTP REAL) ---
# ⚠️ Vacío o Ethereal = los clientes NO reciben emails (van a consola/buzón de pruebas).
#    En producción DEBE ir un SMTP real, o el cliente no recibe el email de "crea tu contraseña".
SMTP_HOST=                                            # ← RELLENAR: host SMTP del proveedor (p.ej. smtp.sendgrid.net)
SMTP_PORT=587
SMTP_USER=                                            # ← RELLENAR
SMTP_PASS=                                            # ← RELLENAR
EMAIL_FROM="Gestadia <hola@gestadia.com>"             # remitente (usa un dominio verificado en el proveedor SMTP)
